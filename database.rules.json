{
  "rules": {
    "users": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": ["email"]
    },
    "tasks": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null"
      }
    },
    "sites": {
      ".read": "auth != null",
      ".write": "auth != null"
    }
  }
}
